        {
          "code": "ACCT 6203",
          "changes": [
            {
              "field": "description",
              "before": "Provides an in-depth look at the structure of the federal income tax system as it relates to different taxable entitites. Emphasizes tax compliance, planning, and research as they impact the decision-making process for corporation and flow-through entities. Also examines the implications of wealth transfer taxes.",
              "after": "Provides an in-depth look at the structure of the federal income tax system as it relates to different taxable entities. Emphasizes tax compliance, planning, and research as they impact the decision-making process for corporation and flow-through entities. Also examines the implications of wealth transfer taxes."
            }
          ]
